<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{project.name}} - Project Detail</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light py-3 navbar-glass">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand fw-bold fs-3 text-dark" href="/">NOUVAL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/">Home</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/#projects">Projects</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/my-project">My Projects</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/contact">Contact</a></li>
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    <button class="theme-toggle me-2" id="themeToggle" aria-label="Toggle dark mode">
                        <i class="fas fa-moon"></i>
                    </button>
                    <a href="/my-project" class="btn btn-outline-dark rounded-pill px-4 btn-sm">Back to Projects</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        <h1 class="text-center fw-bold mb-5 mt-4">{{project.name}}</h1>
        
        <div class="row">
            <div class="col-lg-8 mb-4">
                <img src="{{project.image}}" alt="{{project.name}}" class="img-fluid w-100 rounded-4 shadow-sm object-fit-cover" style="max-height: 450px;">
            </div>
            
            <div class="col-lg-4">
                <h4 class="fw-bold mb-3">Duration</h4>
                <p class="text-secondary fw-medium">
                    <i class="fa-solid fa-calendar-days fs-5 me-2 text-dark"></i> {{project.startDate}} - {{project.endDate}}
                </p>
                <p class="text-secondary fw-medium mb-4">
                    <i class="fa-regular fa-clock fs-5 me-2 text-dark"></i> {{project.duration}}
                </p>
                
                <h4 class="fw-bold mb-3">Technologies</h4>
                <div class="d-flex flex-column gap-2 text-secondary fw-medium mb-4">
                    {{#each project.technologies}}
                        <p class="mb-1">
                            <i class="fa-solid fa-code fs-5 me-2 text-dark"></i> {{this}}
                        </p>
                    {{/each}}
                </div>

                <div class="d-flex flex-column gap-2 mt-4">
                    {{#if project.repository}}
                        <a href="{{project.repository}}" target="_blank" class="btn btn-dark rounded-pill">
                            <i class="fab fa-github me-2"></i> Source Code
                        </a>
                    {{/if}}
                    {{#if project.live_demo}}
                        <a href="{{project.live_demo}}" target="_blank" class="btn btn-outline-dark rounded-pill">
                            <i class="fas fa-external-link-alt me-2"></i> Live Demo
                        </a>
                    {{/if}}
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-12">
                <p class="text-justify" style="line-height: 1.8; white-space: pre-wrap;">{{project.description}}</p>
            </div>
        </div>
        
        <div class="text-center mt-5">
            <a href="/my-project" class="btn btn-outline-dark rounded-pill px-5 fw-bold">Kembali ke Portofolio</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>