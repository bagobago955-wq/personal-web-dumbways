<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Project - Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light py-3 navbar-glass">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand fw-bold fs-3 text-dark" href="/">NOUVAL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item mx-2">
                        <a class="nav-link text-dark" href="/">Home</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-dark" href="/">Tech Stack</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-dark" href="/">Experience</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link active text-dark" href="/my-project">Projects</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-dark" href="/contact">Contact Me</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    <button class="theme-toggle me-2" id="themeToggle" aria-label="Toggle dark mode">
                        <i class="fas fa-moon"></i>
                    </button>
                    {{#if user}}
                        <span class="text-dark fw-medium me-2">{{user.name}}</span>
                        <a href="/logout" class="btn btn-outline-dark rounded-pill px-4 btn-sm">Logout</a>
                    {{else}}
                        <a href="/login" class="btn btn-dark rounded-pill px-4 btn-sm">Login</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row justify-content-center mb-5">
            <div class="col-md-8 col-lg-6">
                
                {{#if messages.success}}
                    <div class="alert alert-success alert-dismissible fade show text-center rounded-pill mb-4" role="alert">
                        <strong>Sukses!</strong> {{messages.success}}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {{/if}}

                {{#if messages.error}}
                    <div class="alert alert-danger alert-dismissible fade show text-center rounded-pill mb-4" role="alert">
                        <strong>Peringatan!</strong> {{messages.error}}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {{/if}}

                {{#if user}}
                    <h2 class="text-center fw-bold mb-4">ADD MY PROJECT</h2>
                    
                    <form action="/my-project" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="projectName" class="form-label fw-bold">Project Name</label>
                            <input type="text" class="form-control custom-input" id="projectName" name="projectName" required>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label fw-bold">Start Date</label>
                                <input type="date" class="form-control custom-input" id="startDate" name="startDate" required>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label for="endDate" class="form-label fw-bold">End Date</label>
                                <input type="date" class="form-control custom-input" id="endDate" name="endDate" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label fw-bold">Description</label>
                            <textarea class="form-control custom-input" id="description" name="description" rows="4" required></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="repository" class="form-label fw-bold">Repository URL <span class="text-secondary fw-normal">(Optional)</span></label>
                                <input type="url" class="form-control custom-input" id="repository" name="repository" placeholder="https://github.com/username/repo">
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label for="liveDemo" class="form-label fw-bold">Live Demo URL <span class="text-secondary fw-normal">(Optional)</span></label>
                                <input type="url" class="form-control custom-input" id="liveDemo" name="live_demo" placeholder="https://your-project.vercel.app">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Technologies</label>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input tech-checkbox" type="checkbox" name="technologies" value="Node Js" id="nodeJs">
                                        <label class="form-check-label text-secondary fw-medium" for="nodeJs">Node Js</label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input tech-checkbox" type="checkbox" name="technologies" value="Next Js" id="nextJs">
                                        <label class="form-check-label text-secondary fw-medium" for="nextJs">Next Js</label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input tech-checkbox" type="checkbox" name="technologies" value="React Js" id="reactJs">
                                        <label class="form-check-label text-secondary fw-medium" for="reactJs">React Js</label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input tech-checkbox" type="checkbox" name="technologies" value="TypeScript" id="typeScript">
                                        <label class="form-check-label text-secondary fw-medium" for="typeScript">TypeScript</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="uploadImage" class="form-label fw-bold">Upload Image (Optional)</label>
                            <div class="input-group custom-input overflow-hidden p-0">
                                <input type="file" class="form-control border-0" id="uploadImage" name="uploadImage" accept="image/*">
                            </div>
                            <div class="form-text mt-2">Leave empty to use default image.</div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold">Add Project</button>
                        </div>
                    </form>
                {{else}}
                    <div class="text-center text-secondary py-5">
                        <i class="fas fa-lock fs-1 mb-3 text-muted"></i>
                        <h5>Silakan <a href="/login" class="text-dark fw-bold">Login</a> untuk menambahkan project baru.</h5>
                    </div>
                {{/if}}
                </div>
        </div>

        <hr class="mb-5">
        <h2 class="text-center fw-bold mb-4">MY PROJECT</h2>
        
        <div class="mb-5 text-center">
            <h5 class="fw-bold mb-3 text-secondary">Filter by Technology</h5>
            <div class="btn-group flex-wrap gap-2" role="group">
                <button type="button" class="btn btn-outline-dark rounded-pill filter-btn active" onclick="filterProjects('All', event)">All Projects</button>
                <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('Node Js', event)">Node Js</button>
                <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('Next Js', event)">Next Js</button>
                <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('React Js', event)">React Js</button>
                <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('TypeScript', event)">TypeScript</button>
            </div>
        </div>

        <div id="projectsContainer" class="row g-4">
            {{#each projects}}
            <div class="col-md-6 col-lg-4 project-card-wrapper" data-tech="{{this.technologies}}">
                <div class="card border-0 rounded-4 shadow-sm p-3 h-100 project-card-hover">
                    <img src="{{this.image}}" class="card-img-top rounded-3 mb-3 object-fit-cover skeleton" height="200" alt="project" onload="this.classList.remove('skeleton')">
                    <div class="card-body p-0 d-flex flex-column">
                        <h5 class="fw-bold mb-1">
                            <a href="/project/{{this.id}}" class="text-dark text-decoration-none hover-blue">{{this.name}}</a>
                        </h5>
                        <p class="text-secondary small mb-3">durasi: {{this.duration}}</p>
                        <p class="text-secondary flex-grow-1" style="font-size: 0.9rem;">
                            {{this.description}}
                        </p>
                        
                        <div class="mb-3 text-dark d-flex flex-wrap gap-2">
                            {{#each this.technologies}}
                                <span class="badge bg-secondary">{{this}}</span>
                            {{/each}}
                        </div>
                        
                        <div class="d-flex gap-2 mb-3 mt-auto">
                            {{#if this.repository}}
                                <a href="{{this.repository}}" target="_blank" class="btn btn-outline-dark btn-sm rounded-pill flex-fill">
                                    <i class="fab fa-github"></i> Repo
                                </a>
                            {{/if}}
                            {{#if this.live_demo}}
                                <a href="{{this.live_demo}}" target="_blank" class="btn btn-dark btn-sm rounded-pill flex-fill">
                                    <i class="fas fa-external-link-alt"></i> Demo
                                </a>
                            {{/if}}
                        </div>
                        
                        {{#if this.isOwner}}
                            <div class="d-flex gap-2 mt-auto">
                                <a href="/edit-project/{{this.id}}" class="btn btn-dark w-100 rounded-pill btn-sm">edit</a>
                                
                                <form action="/delete-project/{{this.id}}" method="POST" class="w-100">
                                    <button type="submit" class="btn btn-danger w-100 rounded-pill btn-sm">delete</button>
                                </form>
                            </div>
                        {{else}}
                            <div class="mt-auto pt-2 border-top">
                                <span class="text-secondary small fw-bold"><i class="fas fa-user-edit me-1"></i> Author: {{this.author}}</span>
                            </div>
                        {{/if}}
                        </div>
                </div>
            </div>
            {{else}}
            <div class="col-12">
                <p class="text-center text-secondary w-100">Project tidak ditemukan. Silakan tambahkan project baru.</p>
            </div>
            {{/each}}
        </div>
    </div>

    <script>
        function filterProjects(tech, event) {
            // Update styling tombol aktif
            if(event) {
                document.querySelectorAll('.filter-btn').forEach(btn => {
                    btn.classList.remove('active', 'btn-dark');
                    btn.classList.add('btn-outline-dark');
                });
                event.target.classList.remove('btn-outline-dark');
                event.target.classList.add('active', 'btn-dark');
            }

            // Seleksi semua card yang dirender oleh Handlebars
            const cards = document.querySelectorAll('.project-card-wrapper');
            
            cards.forEach(card => {
                card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                const cardTechs = card.getAttribute('data-tech');
                
                // Jika filter adalah 'All' atau array technologies dari card (sebagai string) memiliki tech yang di-klik
                if (tech === 'All' || cardTechs.includes(tech)) {
                    card.style.display = 'block';
                    setTimeout(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'scale(1)';
                    }, 10);
                } else {
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.9)';
                    setTimeout(() => {
                        if (card.style.opacity === '0') {
                            card.style.display = 'none';
                        }
                    }, 400);
                }
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>