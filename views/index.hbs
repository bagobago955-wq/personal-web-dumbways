    <section id="projects" class="section-block py-5">
        <div class="container px-4 px-lg-5">
            <h2 class="text-center fw-bold mb-4">MY PROJECT</h2>

            <div class="mb-5 text-center">
                <h5 class="fw-bold mb-3 text-secondary">Filter by Technology</h5>
                <div class="btn-group flex-wrap gap-2" role="group">
                    <button type="button" class="btn btn-outline-dark rounded-pill filter-btn active" onclick="filterProjects('All', event)">All Projects</button>
                    <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('Node Js', event)">Node Js</button>
                    <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('Next Js', event)">Next Js</button>
                    <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('React Js', event)">React Js</button>
                    <button type="button" class="btn btn-outline-dark rounded-pill filter-btn" onclick="filterProjects('TypeScript', event)">TypeScript</button>
                </div>
            </div>

            <div id="projectsContainer" class="row g-4">
                {{#each projects}}
                <div class="col-md-6 col-lg-4 project-card-wrapper" data-tech="{{this.technologies}}">
                    <div class="card border-0 rounded-4 shadow-sm p-3 h-100 project-card-hover">
                        <img src="{{this.image}}" class="card-img-top rounded-3 mb-3 object-fit-cover skeleton" height="200" alt="project" onload="this.classList.remove('skeleton')">
                        <div class="card-body p-0 d-flex flex-column">
                            <h5 class="fw-bold mb-1">
                                <a href="/project/{{this.id}}" class="text-dark text-decoration-none hover-blue">{{this.name}}</a>
                            </h5>
                            <p class="text-secondary small mb-3">durasi: {{this.duration}}</p>
                            <p class="text-secondary flex-grow-1" style="font-size: 0.9rem;">
                                {{this.description}}
                            </p>

                            <div class="mb-3 text-dark d-flex flex-wrap gap-2">
                                {{#each this.technologies}}
                                    <span class="badge bg-secondary">{{this}}</span>
                                {{/each}}
                            </div>

                            <div class="d-flex gap-2 mb-3 mt-auto">
                                {{#if this.repository}}
                                    <a href="{{this.repository}}" target="_blank" class="btn btn-outline-dark btn-sm rounded-pill flex-fill">
                                        <i class="fab fa-github"></i> Repo
                                    </a>
                                {{/if}}
                                {{#if this.live_demo}}
                                    <a href="{{this.live_demo}}" target="_blank" class="btn btn-dark btn-sm rounded-pill flex-fill">
                                        <i class="fas fa-external-link-alt"></i> Demo
                                    </a>
                                {{/if}}
                            </div>

                            {{#if this.isOwner}}
                                <div class="d-flex gap-2 mt-auto">
                                    <a href="/edit-project/{{this.id}}" class="btn btn-dark w-100 rounded-pill btn-sm">edit</a>
                                    <form action="/delete-project/{{this.id}}" method="POST" class="w-100">
                                        <button type="submit" class="btn btn-danger w-100 rounded-pill btn-sm">delete</button>
                                    </form>
                                </div>
                            {{else}}
                                <div class="mt-auto pt-2 border-top">
                                    <span class="text-secondary small fw-bold"><i class="fas fa-user-edit me-1"></i> Author: {{this.author}}</span>
                                </div>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{else}}
                <div class="col-12">
                    <p class="text-center text-secondary w-100">Project tidak ditemukan. Silakan tambahkan project baru.</p>
                </div>
                {{/each}}
            </div>

            <div class="text-center mt-5">
                <a href="/my-project" class="btn btn-dark rounded-pill px-5 py-2">View More & Add Project</a>
            </div>
        </div>
    </section>

