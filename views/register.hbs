<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Nouval Portfolio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light py-3 navbar-glass">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand fw-bold fs-3 text-dark" href="/">NOUVAL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/">Home</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/#stack">Tech Stack</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/my-project">Projects</a></li>
                    <li class="nav-item mx-2"><a class="nav-link text-dark" href="/contact">Contact</a></li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="/login" class="btn btn-dark rounded-pill px-4 btn-sm">Sign In</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center min-vh-100 align-items-center">
            <div class="col-md-5">
                {{#if messages.error}}
                    <div class="alert alert-danger text-center rounded-4 mb-4">
                        <i class="fas fa-exclamation-circle me-2"></i>{{messages.error}}
                    </div>
                {{/if}}

                <div class="card border-0 shadow-sm rounded-4 p-5 bg-white">
                    <h2 class="text-center fw-bold mb-4">Create Account</h2>
                    <p class=\"text-center text-secondary mb-4\">Join Nouval's portfolio platform today.</p>
                    <form action="/register" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input type="text" class="form-control custom-input" name="name" placeholder="John Doe" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input type="email" class="form-control custom-input" name="email" placeholder="your@email.com" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Password</label>
                            <input type="password" class="form-control custom-input" name="password" placeholder="••••••••" required>
                        </div>
                        <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2">Create Account</button>
                        <p class="text-center mt-4 small text-secondary">Already have an account? <a href="/login" class="text-dark fw-bold">Sign in</a></p>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>