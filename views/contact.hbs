<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Me - Nouval Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light py-3 navbar-glass">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand fw-bold fs-3" href="/">NOUVAL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="/#stack">Tech Stack</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="/#experience">Experience</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="/my-project">Projects</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link active" href="/contact">Contact Me</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    <a href="https://wa.me/6283836487767" target="_blank" class="btn btn-success rounded-pill px-4"><i class="fab fa-whatsapp me-1"></i> Let's Talk</a>
                    <a href="/images/CV_Muhammad Nouval Ar-Rizqy.pdf"
                        class="btn btn-warning rounded-pill px-4 text-white">Download CV</a>
                    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main class="py-5">
        <div class="container px-4 px-lg-5">
            <div class="row justify-content-center">
                <div class="col-xl-8">
                    <div class="contact-card rounded-4 p-5 shadow-sm">
                        <div class="text-center mb-4">
                            <h1 class="fw-bold">Contact Me</h1>
                            <p class="text-secondary mb-0">Interested in collaborating, discussing a project, or just saying hello? Send a message through this form.</p>
                        </div>
                        <form action="mailto:bagobago955@gmail.com" method="post" enctype="text/plain">
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label for="inputName" class="form-label fw-semibold">Name</label>
                                    <input type="text" class="form-control custom-input" id="inputName" name="Name" placeholder="Full name" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="inputEmail" class="form-label fw-semibold">Email</label>
                                    <input type="email" class="form-control custom-input" id="inputEmail" name="Email" placeholder="name@email.com" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="inputMessage" class="form-label fw-semibold">Message</label>
                                <textarea class="form-control custom-input" id="inputMessage" name="Message" rows="6" placeholder="Write your message here" required></textarea>
                            </div>
                            <div class="text-end mt-4">
                                <button type="submit" class="btn btn-dark rounded-pill px-5 py-2">Send Message</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>